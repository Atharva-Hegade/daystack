{
  "name": "daystack",
  "version": "1.0.0",
  "description": "DayStack - Smart Daily Task Manager",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.daystack.app",
    "productName": "DayStack",
    "directories": { "output": "dist-electron" },
    "win": {
      "target": "dir",
      "icon": "public/icon.ico",
      "signAndEditExecutable": false,
      "sign": null
    },
    "mac": {
      "sign": null,
      "notarize": false
    },
    "linux": {
      "target": "dir"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "electron-store": "^8.2.0"
  }
}
